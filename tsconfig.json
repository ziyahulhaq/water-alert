{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ]
    }
  },
  "include": [
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/hooks/**/*.ts",
    "src/hooks/**/*.tsx",
    "src/lib/ble-constants.ts",
    "src/lib/hash.ts",
    "src/lib/mock-storage.ts",
    "src/lib/notifications.ts",
    "src/lib/storage-client.ts",
    "src/lib/supabase.ts",
    "src/lib/time-utils.ts",
    "src/theme/**/*.ts",
    "src/theme/**/*.tsx",
    "src/types/**/*.ts",
    "src/constants/**/*.ts",
    "src/components/Header.tsx",
    "src/components/PulseDot.tsx",
    "src/components/timeline-item.tsx",
    "src/components/simulator-panel.tsx",
    "src/components/telegram-card.tsx",
    "src/components/themed-text.tsx",
    "src/components/themed-view.tsx",
    "src/components/external-link.tsx",
    "src/components/animated-icon.tsx",
    "src/components/ui/**/*.ts",
    "src/components/ui/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
