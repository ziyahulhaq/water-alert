# Supabase Connection Keys
# Copy this file to .env and fill in your details to connect the web app to a live Supabase instance.
# If these variables are not configured or are left as placeholder values, the app will run in "Demo Mode" using local storage.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Telegram Bot Username (without the @ symbol)
# Go to Telegram → open your bot → click the bot name → copy username
VITE_TELEGRAM_BOT_USERNAME=YourBotUsername

# VAPID Public Key for Web Push Notifications
# Generate a key pair with: npx web-push generate-vapid-keys
# Paste the public key below (the long base64url string)
VITE_VAPID_PUBLIC_KEY=
